# ─────────────────────────────────────────────────────────────────
# .env.example — copy to .env and edit as needed
# ─────────────────────────────────────────────────────────────────

# Device: 'cuda' | 'cpu' | 'auto'
DEVICE=auto

# Model checkpoints (HuggingFace Hub IDs)
# Small = faster, Large = more accurate
RELATIVE_MODEL_CHECKPOINT=depth-anything/Depth-Anything-V2-Small-hf
METRIC_MODEL_CHECKPOINT=Intel/zoedepth-nyu-kitti

# Max image size (longest edge in pixels, larger images are downscaled)
MAX_IMAGE_SIZE=1920

# Max upload size in MB
MAX_UPLOAD_MB=20

# Depth map colour scheme: inferno | plasma | magma | viridis | turbo
COLORMAP=inferno

# Inference timeout in seconds
INFERENCE_TIMEOUT_SECONDS=60.0

# CORS — use specific origins in production
CORS_ORIGINS=["*"]
